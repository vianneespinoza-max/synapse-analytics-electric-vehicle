						{
							"type": "NonQuery",
							"text": "USE electric_vehicle_ldw"
						},
						{
							"type": "Query",
							"text": "DROP VIEW IF EXISTS\ngold.vw_quantity_of_vehicle_by_type"
						},
						{
							"type": "Query",
							"text": "CREATE VIEW gold.vw_quantity_of_vehicle_by_type\nAS\n    SELECT *\n    FROM\n    OPENROWSET(\n        BULK 'gold/quantity_of_vehicle_by_type/year=*/month=*/*.parquet',\n        DATA_SOURCE = 'electric_vehicle_source',\n        FORMAT = 'PARQUET'\n    )\n    WITH(\n        year                    SMALLINT,\n        month                   TINYINT,\n        make                    VARCHAR(25),\n        electric_vehicle_type   VARCHAR(40),\n        vehicle_register_count  INT\n    )\n    AS [result];"
						}
